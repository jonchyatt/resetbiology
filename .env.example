# Auth0 v4 Configuration (REQUIRED - fill in on Vercel)
AUTH0_ISSUER_BASE_URL=https://dev-xxx.us.auth0.com  # Your Auth0 tenant URL (no trailing slash)
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=generate-32-plus-char-random-string  # For cookie encryption (min 32 chars)
AUTH0_BASE_URL=https://resetbiology.com  # MUST match the domain users access (no trailing slash)

# Database Configuration
DATABASE_URL="mongodb+srv://USER:PASS@HOST/resetbiology?retryWrites=true&w=majority&appName=Cluster0"

# Application URLs
APP_BASE_URL=https://resetbiology.com  # Used for Stripe success/cancel URLs

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_xxx  # Use sandbox key for non-production
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx\n# Nutrition data providers\nUSDA_API_KEY=\nOPENFOODFACTS_APP_NAME=resetbiology

# Google Drive OAuth client ID for vault sync
GOOGLE_CLIENT_ID=
# Google Drive OAuth client secret for vault sync
GOOGLE_CLIENT_SECRET=
# Google Drive OAuth redirect URI registered in Google Cloud
GOOGLE_REDIRECT_URI=
# AES-256-GCM key used to encrypt stored Drive refresh tokens
VAULT_TOKEN_KEY=
# Shared secret for authenticated cron routes
CRON_SECRET=

# Journal read-path authority flip (Phase C, cf-c2-journal-inversion).
# Dark by default (unset/anything other than "1" = OFF = today's Mongo-only
# behavior). Set to "1" to let Drive become read/write truth for the journal
# domain — ONLY takes effect for a given user once isVaultConnected AND a
# verified MigrationManifest(userId, 'journal') row also exist. See
# src/lib/drive-read-authority.ts.
DRIVE_READ_AUTHORITY_JOURNAL=
